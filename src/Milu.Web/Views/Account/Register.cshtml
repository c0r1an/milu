@model RegisterViewModel

@{
    ViewData["Title"] = "Registrieren";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h1 class="h3">Benutzerkonto erstellen</h1>
                <p class="text-muted">Neue Konten erhalten automatisch die Grundrechte der Gruppe „Registered“.</p>
                <form action="/account/register" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    <div class="mb-3"><label asp-for="UserName" class="form-label"></label><input asp-for="UserName" class="form-control" autocomplete="username" /></div>
                    <div class="mb-3"><label asp-for="DisplayName" class="form-label"></label><input asp-for="DisplayName" class="form-control" autocomplete="name" /></div>
                    <div class="mb-3"><label asp-for="Email" class="form-label"></label><input asp-for="Email" class="form-control" autocomplete="email" /></div>
                    <div class="mb-3"><label asp-for="Password" class="form-label"></label><input asp-for="Password" class="form-control" autocomplete="new-password" /></div>
                    <div class="mb-3"><label asp-for="ConfirmPassword" class="form-label"></label><input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" /></div>
                    <button class="btn btn-primary w-100" type="submit">Registrieren</button>
                </form>
                <p class="text-center mt-3 mb-0"><a href="/account/login">Bereits registriert?</a></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
