<div class="d-flex align-items-center gap-2 ms-auto">@if (User.Identity?.IsAuthenticated == true) { <span class="small">@User.Identity.Name</span><form action="/account/logout" method="post">@Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-secondary">Abmelden</button></form> } else { <a class="btn btn-sm btn-outline-primary" href="/account/login">Anmelden</a><a class="btn btn-sm btn-primary" href="/account/register">Registrieren</a> }</div>
