<!DOCTYPE html><html lang="de"><head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
<title>@ViewData["Title"] - Milu</title><link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /><link rel="stylesheet" href="~/css/site.css" asp-append-version="true" /><link rel="stylesheet" href="~/css/layouts.css" asp-append-version="true" /></head>
<body class="layout-classic"><header><nav class="navbar navbar-expand-lg bg-white border-bottom mb-4"><div class="container"><a class="navbar-brand fw-bold" href="/">Milu</a><button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#classicNav"><span class="navbar-toggler-icon"></span></button><div class="collapse navbar-collapse" id="classicNav"><ul class="navbar-nav me-auto">@foreach (var module in ModuleCatalog.Modules.Where(x => x.ShowInFrontendNavigation)) { if (await PermissionService.HasPermissionAsync(User,module.Key,PermissionOperation.ModuleView)) { <li class="nav-item"><a class="nav-link" href="@module.FrontendRoute">@module.DisplayName</a></li> } }</ul><partial name="_FrontendAccountLinks" /></div></div></nav></header>
<main class="container pb-5">@RenderBody()</main><footer class="border-top py-3 text-muted"><div class="container">© 2026 Milu</div></footer><partial name="_FrontendScripts" />@await RenderSectionAsync("Scripts", false)</body></html>
