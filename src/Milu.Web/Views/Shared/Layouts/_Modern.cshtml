<!DOCTYPE html><html lang="de"><head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
<title>@ViewData["Title"] - Milu</title><link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /><link rel="stylesheet" href="~/css/site.css" asp-append-version="true" /><link rel="stylesheet" href="~/css/layouts.css" asp-append-version="true" /></head>
<body class="layout-modern"><header class="modern-header"><div class="container py-4"><div class="d-flex align-items-center justify-content-between"><a class="display-6 fw-bold text-white text-decoration-none" href="/">MILU</a><partial name="_FrontendAccountLinks" /></div><nav class="nav mt-4 gap-2">@foreach (var module in ModuleCatalog.Modules.Where(x => x.ShowInFrontendNavigation)) { if (await PermissionService.HasPermissionAsync(User,module.Key,PermissionOperation.ModuleView)) { <a class="nav-link modern-nav-link" href="@module.FrontendRoute">@module.DisplayName</a> } }</nav></div></header>
<main class="container modern-content py-5">@RenderBody()</main><footer class="py-5 text-center text-muted">Milu · Modern Layout</footer><partial name="_FrontendScripts" />@await RenderSectionAsync("Scripts", false)</body></html>
