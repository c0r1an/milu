<!DOCTYPE html><html lang="de"><head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
<title>@ViewData["Title"] - Milu</title><link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /><link rel="stylesheet" href="~/css/site.css" asp-append-version="true" /><link rel="stylesheet" href="~/css/layouts.css" asp-append-version="true" /></head>
<body class="layout-minimal"><header class="container minimal-header py-4"><div class="d-flex flex-wrap align-items-center justify-content-between gap-3"><a class="h3 m-0 text-dark text-decoration-none" href="/">milu.</a><nav class="d-flex gap-4">@foreach (var module in ModuleCatalog.Modules.Where(x => x.ShowInFrontendNavigation)) { if (await PermissionService.HasPermissionAsync(User,module.Key,PermissionOperation.ModuleView)) { <a class="minimal-link" href="@module.FrontendRoute">@module.DisplayName</a> } }</nav><partial name="_FrontendAccountLinks" /></div></header>
<main class="container minimal-content py-5">@RenderBody()</main><partial name="_FrontendScripts" />@await RenderSectionAsync("Scripts", false)</body></html>
