<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Milu</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Milu.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-semibold" href="/">Milu</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav">
                        @foreach (var module in ModuleCatalog.Modules.Where(item => item.ShowInFrontendNavigation))
                        {
                            @if (await PermissionService.HasPermissionAsync(User, module.Key, PermissionOperation.ModuleView))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="@module.FrontendRoute">@module.DisplayName</a>
                                </li>
                            }
                        }
                        @if (await PermissionService.HasPermissionAsync(User, "admin", PermissionOperation.ModuleView))
                        {
                            <li class="nav-item"><a class="nav-link text-dark" href="/admin">Administration</a></li>
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="text-muted small">@User.Identity.Name</span>
                            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                <button class="btn btn-sm btn-outline-secondary" type="submit">Abmelden</button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-sm btn-outline-primary" href="/account/login">Anmelden</a>
                            <a class="btn btn-sm btn-primary" href="/account/register">Registrieren</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Milu · Modularer ASP.NET-Core-MVC-Prototyp
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/tinymce-package/tinymce.min.js"></script>
    <script src="/modules/media/media-picker.js"></script>
    <script src="~/js/milu-editor.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
