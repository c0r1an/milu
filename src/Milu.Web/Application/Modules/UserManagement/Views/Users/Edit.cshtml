@model UserEditViewModel

@{ ViewData["Title"] = "Benutzer bearbeiten"; }

<h1>Benutzer bearbeiten</h1><p class="text-muted">@Model.Email</p>
<form action="/admin/users/edit/@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <div class="card mb-4"><div class="card-body">
        <div class="mb-3"><label class="form-label" for="displayName">Anzeigename</label><input class="form-control" id="displayName" name="displayName" value="@Model.DisplayName" maxlength="120" required /></div>
        <div class="form-check mb-3"><input class="form-check-input" type="checkbox" name="isActive" value="true" id="isActive" checked="@Model.IsActive" /><label class="form-check-label" for="isActive">Benutzer ist aktiv</label></div>
        <fieldset><legend class="h5">Gruppen</legend><div class="row">@foreach (var role in Model.Roles) { <div class="col-md-4"><div class="form-check"><input class="form-check-input" type="checkbox" name="roleIds" value="@role.Id" id="role-@role.Id" checked="@role.Selected" /><label class="form-check-label" for="role-@role.Id">@role.Name</label></div></div> }</div></fieldset>
    </div></div>
    <div class="card mb-4"><div class="card-body"><h2 class="h4">Individuelle Rechte</h2><p class="text-muted">Einzelrechte überschreiben alle Gruppenrechte. „Vererben“ verwendet die Gruppen.</p>
        <div class="table-responsive"><table class="table table-sm align-middle"><thead><tr><th>Modul</th><th>Recht</th><th>Entscheidung</th></tr></thead><tbody>
        @foreach (var permission in Model.Permissions) { <tr><td>@permission.ModuleName</td><td>@permission.OperationName</td><td><select class="form-select form-select-sm" name="permissionAssignments"><option value="@permission.ModuleKey|@permission.Operation|inherit" selected="@(permission.Decision == "inherit")">Vererben</option><option value="@permission.ModuleKey|@permission.Operation|allow" selected="@(permission.Decision == "allow")">Erlauben</option><option value="@permission.ModuleKey|@permission.Operation|deny" selected="@(permission.Decision == "deny")">Verbieten</option></select></td></tr> }
        </tbody></table></div>
    </div></div>
    <button class="btn btn-primary" type="submit">Alles speichern</button><a class="btn btn-link" href="/admin/users">Abbrechen</a>
</form>
