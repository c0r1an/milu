@model IReadOnlyCollection<UserListItem>

@{ ViewData["Title"] = "Benutzerverwaltung"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h1>Benutzerverwaltung</h1><p class="text-muted mb-0">Benutzer, Gruppen und individuelle Rechte.</p></div>
    <div class="d-flex gap-2"><a class="btn btn-outline-primary" href="/admin/groups">Gruppen</a><a class="btn btn-primary" href="/admin/users/create">Benutzer anlegen</a></div>
</div>
@if (TempData["SuccessMessage"] is string success) { <div class="alert alert-success">@success</div> }
@if (TempData["ErrorMessage"] is string error) { <div class="alert alert-danger">@error</div> }

<div class="table-responsive bg-white border rounded">
    <table class="table table-hover align-middle mb-0">
        <thead><tr><th>Benutzer</th><th>Gruppen</th><th>Status</th><th>Erstellt</th><th class="text-end">Aktionen</th></tr></thead>
        <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td><strong>@user.DisplayName</strong><br /><span class="text-muted small">@user.Email</span></td>
                <td>@string.Join(", ", user.Groups)</td>
                <td><span class="badge @(user.IsActive ? "text-bg-success" : "text-bg-secondary")">@(user.IsActive ? "Aktiv" : "Deaktiviert")</span></td>
                <td>@user.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                <td class="text-end text-nowrap">
                    <a class="btn btn-sm btn-outline-primary" href="/admin/users/edit/@user.Id">Bearbeiten</a>
                    <form class="d-inline" action="/admin/users/delete/@user.Id" method="post" onsubmit="return confirm('Benutzer wirklich löschen?');">@Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-danger">Löschen</button></form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
