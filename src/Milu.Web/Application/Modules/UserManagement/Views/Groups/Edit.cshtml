@model GroupEditViewModel

@{ ViewData["Title"] = Model.Id is null ? "Gruppe erstellen" : "Gruppe bearbeiten"; var action = Model.Id is null ? "/admin/groups/create" : $"/admin/groups/edit/{Model.Id}"; }

<h1>@ViewData["Title"]</h1>
<form action="@action" method="post">
    @Html.AntiForgeryToken()
    <div class="card mb-4"><div class="card-body"><div asp-validation-summary="All" class="text-danger"></div><div class="mb-3"><label class="form-label" for="name">Gruppenname</label><input class="form-control" id="name" name="name" value="@Model.Name" readonly="@Model.IsSystemRole" required maxlength="100" /></div><div><label class="form-label" for="description">Beschreibung</label><textarea class="form-control" id="description" name="description" maxlength="500">@Model.Description</textarea></div></div></div>
    <div class="card mb-4"><div class="card-body"><h2 class="h4">Gruppenrechte</h2><p class="text-muted">Markierte Rechte werden allen Mitgliedern dieser Gruppe gewährt.</p><div class="table-responsive"><table class="table table-sm align-middle"><thead><tr><th>Modul</th><th>Recht</th><th>Erlauben</th></tr></thead><tbody>
    @foreach (var permission in Model.Permissions) { <tr><td>@permission.ModuleName</td><td>@permission.OperationName</td><td><input class="form-check-input" type="checkbox" name="permissions" value="@permission.ModuleKey|@permission.Operation|allow" checked="@(permission.Decision == "allow")" /></td></tr> }
    </tbody></table></div></div></div>
    <button class="btn btn-primary" type="submit">Speichern</button><a class="btn btn-link" href="/admin/groups">Abbrechen</a>
</form>
