@model MediaDetailsViewModel
@{ ViewData["Title"] = "Medium verwalten"; }
<a href="/admin/media/index/index">← Medienbibliothek</a>
<div class="row mt-3">
    <div class="col-lg-5">
        @if (Model.Asset.ContentType.StartsWith("image/")) { <img class="img-fluid rounded border" src="/media/file/index/id/@Model.Asset.Id" alt="@Model.Asset.AltText" /> }
        else { <div class="media-dropzone"><a href="/media/file/index/id/@Model.Asset.Id">@Model.Asset.FileName öffnen</a></div> }
    </div>
    <div class="col-lg-7">
        @if (TempData["SuccessMessage"] is string message) { <div class="alert alert-success">@message</div> }
        <h1 class="h3">@Model.Asset.FileName</h1>
        <form method="post" action="/admin/media/index/edit/id/@Model.Asset.Id">
            @Html.AntiForgeryToken()
            <div class="mb-3"><label class="form-label">Titel</label><input class="form-control" name="title" maxlength="160" value="@Model.Asset.Title" /></div>
            <div class="mb-3"><label class="form-label">Alternativtext / Beschreibung</label><textarea class="form-control" name="altText" maxlength="500">@Model.Asset.AltText</textarea></div>
            <button class="btn btn-primary">Speichern</button>
        </form>
        <hr /><h2 class="h5">Verwendet in</h2>
        @if (Model.Usages.Count == 0) { <p class="text-muted">Dieses Medium wird derzeit nicht verwendet.</p> }
        else { <ul>@foreach (var usage in Model.Usages) { <li>@if (usage.EditUrl is not null) { <a href="@usage.EditUrl">@usage.DisplayName</a> } else { @usage.DisplayName } <span class="text-muted">(@usage.ModuleKey · @usage.FieldName)</span></li> }</ul> }
        <button type="button" class="btn btn-outline-danger mt-3" id="deleteMedia" data-id="@Model.Asset.Id" @(Model.Usages.Count > 0 ? "disabled" : null)>Löschen</button>
    </div>
</div>
@section Scripts { <script src="/modules/media/media.js"></script> }
