@model IReadOnlyCollection<NewsArticle>

@{
    ViewData["Title"] = "News";
}

<div class="mb-4">
    <h1>News</h1>
    <p class="text-muted">Aktuelle Beiträge aus Milu.</p>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Zurzeit sind keine News veröffentlicht.</div>
}
else
{
    <div class="row g-4">
        @foreach (var article in Model)
        {
            <div class="col-md-6">
                <article class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <time class="small text-muted">@article.PublishedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</time>
                        <h2 class="h4 mt-2">@article.Title</h2>
                        <p>@article.Summary</p>
                        <a class="btn btn-outline-primary mt-auto align-self-start" href="/news/index/details/id/@article.Id">Weiterlesen</a>
                    </div>
                </article>
            </div>
        }
    </div>
}
