@model NewsInputModel

@{
    ViewData["Title"] = "Newsbeitrag erstellen";
}

<h1>Newsbeitrag erstellen</h1>

<form action="/admin/news/index/create" method="post" class="card" data-rich-text-form>
    @Html.AntiForgeryToken()
    <div class="card-body">
        <div asp-validation-summary="All" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" name="Title" class="form-control" maxlength="160" />
        </div>
        <div class="mb-3">
            <label asp-for="Summary" class="form-label"></label>
            <textarea asp-for="Summary" name="Summary" class="form-control" rows="3" maxlength="500"></textarea>
        </div>
        <div class="mb-3">
            <label asp-for="Content" class="form-label"></label>
            <textarea asp-for="Content" name="Content" class="form-control" rows="10" maxlength="10000" data-editor-preset="admin"></textarea>
        </div>
        <div class="mb-3">
            <label asp-for="FeaturedMediaId" class="form-label"></label>
            <input asp-for="FeaturedMediaId" type="hidden" id="featuredMediaId" />
            <img id="featuredMediaPreview" class="img-thumbnail d-block mb-2" style="max-height:220px" hidden />
            <button type="button" class="btn btn-outline-primary" data-media-picker data-target="#featuredMediaId" data-preview="#featuredMediaPreview">Aus Medien auswählen</button>
            <button type="button" class="btn btn-link" onclick="document.querySelector('#featuredMediaId').value='';document.querySelector('#featuredMediaPreview').hidden=true">Auswahl entfernen</button>
        </div>
        <div class="form-check mb-3">
            <input asp-for="IsPublished" class="form-check-input" />
            <label asp-for="IsPublished" class="form-check-label"></label>
        </div>
        <button class="btn btn-primary" type="submit">Erstellen</button>
        <a class="btn btn-link" href="/admin/news/index/index">Abbrechen</a>
    </div>
</form>
