@model NewsEditViewModel

@{
    ViewData["Title"] = "Newsbeitrag bearbeiten";
}

<h1>Newsbeitrag bearbeiten</h1>
<p class="text-muted">Angelegt am @Model.PublishedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>

<form action="/admin/news/index/edit/id/@Model.Id" method="post" class="card">
    @Html.AntiForgeryToken()
    <div class="card-body">
        <div asp-validation-summary="All" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="Input.Title" class="form-label"></label>
            <input asp-for="Input.Title" name="Title" class="form-control" maxlength="160" />
        </div>
        <div class="mb-3">
            <label asp-for="Input.Summary" class="form-label"></label>
            <textarea asp-for="Input.Summary" name="Summary" class="form-control" rows="3" maxlength="500"></textarea>
        </div>
        <div class="mb-3">
            <label asp-for="Input.Content" class="form-label"></label>
            <textarea asp-for="Input.Content" name="Content" class="form-control" rows="10" maxlength="10000"></textarea>
        </div>
        <div class="form-check mb-3">
            <input asp-for="Input.IsPublished" name="IsPublished" class="form-check-input" />
            <label asp-for="Input.IsPublished" class="form-check-label"></label>
        </div>
        <button class="btn btn-primary" type="submit">Speichern</button>
        <a class="btn btn-link" href="/admin/news/index/index">Abbrechen</a>
    </div>
</form>
