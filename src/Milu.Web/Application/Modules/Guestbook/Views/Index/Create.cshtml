@model GuestbookInputModel

@{
    ViewData["Title"] = "Gästebucheintrag schreiben";
}

<h1>Gästebucheintrag schreiben</h1>
<p class="text-muted">Dein Eintrag wird nach dem Absenden direkt veröffentlicht.</p>

<form action="/guestbook/index/create" method="post" class="card">
    @Html.AntiForgeryToken()
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" maxlength="80" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Message" class="form-label"></label>
            <textarea asp-for="Message" class="form-control" rows="6" maxlength="1000"></textarea>
            <span asp-validation-for="Message" class="text-danger"></span>
        </div>
        <button class="btn btn-primary" type="submit">Eintrag veröffentlichen</button>
        <a class="btn btn-link" href="/guestbook">Abbrechen</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
