@model ModuleManagementViewModel

@{
    ViewData["Title"] = "Module";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Module</h1>
        <p class="text-muted mb-0">Diese Liste entsteht automatisch aus allen registrierten Modulen.</p>
    </div>
    <span class="badge text-bg-primary fs-6">@Model.Modules.Count installiert</span>
</div>

@if (TempData["SuccessMessage"] is string success) { <div class="alert alert-success">@success</div> }
@if (TempData["ErrorMessage"] is string error) { <div class="alert alert-danger">@error</div> }

<section class="card mb-4">
    <div class="card-body">
        <h2 class="h5">Frontend-Startseite</h2>
        <p class="text-muted">Wähle ein Nicht-Core-Modul und optional eine Unterseite. Ohne gültige Auswahl wird das Core-Modul Sample verwendet.</p>
        @if (Model.StartPageModules.Count == 0)
        {
            <div class="alert alert-info mb-0">Kein auswählbares Modul installiert. Aktiver Fallback: <code>/sample</code></div>
        }
        else
        {
            var currentParts = Model.CurrentStartRoute.Split('/', 2);
            <form action="/admin/modules/start-page" method="post" class="row g-3 align-items-end">
                @Html.AntiForgeryToken()
                <div class="col-md-4">
                    <label class="form-label" for="moduleKey">Modul</label>
                    <select class="form-select" id="moduleKey" name="moduleKey" required>
                        @foreach (var module in Model.StartPageModules)
                        {
                            <option value="@module.Key" selected="@(currentParts[0].Equals(module.Key, StringComparison.OrdinalIgnoreCase))">@module.DisplayName</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="subPath">Unterseite <span class="text-muted">(optional)</span></label>
                    <input class="form-control" id="subPath" name="subPath" value="@(currentParts.Length > 1 ? currentParts[1] : "")" placeholder="z. B. index/details/id/1" />
                </div>
                <div class="col-md-2"><button class="btn btn-primary w-100" type="submit">Speichern</button></div>
            </form>
        }
    </div>
</section>

<section class="card mb-4">
    <div class="card-body">
        <h2 class="h5">Pagination</h2>
        <p class="text-muted">Der globale Wert gilt für jedes Modul ohne eigene Einstellung. Erlaubt sind 1 bis 100 Einträge pro Seite.</p>
        <form action="/admin/modules/pagination" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label" for="defaultPageSize">Globaler Standard</label>
                    <input class="form-control" id="defaultPageSize" name="defaultPageSize" type="number" min="1" max="100" value="@Model.DefaultPageSize" required />
                </div>
                @foreach (var module in Model.Modules)
                {
                    <div class="col-md-4">
                        <label class="form-label" for="pageSize-@module.Key">@module.DisplayName</label>
                        <input class="form-control" id="pageSize-@module.Key" name="modulePageSizes[@module.Key]" type="number" min="1" max="100" value="@Model.ModulePageSizes.GetValueOrDefault(module.Key)" placeholder="Globaler Standard (@Model.DefaultPageSize)" />
                    </div>
                }
            </div>
            <button class="btn btn-primary mt-3" type="submit">Pagination speichern</button>
        </form>
    </div>
</section>

<div class="row g-3">
    @foreach (var module in Model.Modules)
    {
        <div class="col-xl-6">
            <article class="card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between gap-3">
                        <div>
                            <h2 class="h5 mb-1">@module.DisplayName</h2>
                            <code>@module.Key</code>
                            @if (module.IsCoreModule) { <span class="badge text-bg-dark ms-2">Core · geschützt</span> }
                        </div>
                        <span class="badge text-bg-light">v@module.Version</span>
                    </div>
                    <p class="mt-3">@module.Description</p>
                    <div class="d-flex gap-2">
                        @if (module.HasAdminArea)
                        {
                            <a class="btn btn-primary btn-sm" href="@module.AdminRoute">Verwalten</a>
                        }
                        @if (module.FrontendRoute != "/admin")
                        {
                            <a class="btn btn-outline-secondary btn-sm" href="@module.FrontendRoute">Frontend</a>
                        }
                    </div>
                </div>
            </article>
        </div>
    }
</div>
